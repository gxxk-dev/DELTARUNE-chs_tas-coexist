# Local game/mod assets and generated build output.
/build/
/output/
/backups/
/work/
/latest_backup.txt
/latest_*_backup.txt
/.dr-tas-chs-*.lock
/.dr-tas-chs-output.*/
/.dr-tas-chs-publish.*/
/.dr-tas-chs-patchset-build.*/

# Generated verification dumps. Keep compact .tsv reports and code lists tracked.
/verify/**/*.gml

# .NET build output.
**/bin/
**/obj/

# Rust build output.
/tools/patcher/target/

# Generated, third-party-derived embedded patcher assets. Keep them local only.
/tools/patcher/assets/

# Local build artifacts and patch sets; do not commit or redistribute them.
/dist/
/patchset/
/patchsets/

# UndertaleModTool/ImportGraphics may emit this when run from a local checkout.
/Packager/

# Logs and local machine files.
*.log
*.tmp
*.bak
.DS_Store
Thumbs.db

# Binary game/mod assets should not be published in this research repo.
*.win
*.bps
*.xdelta
*.mp4
*.ogg
*.wav
*.exe
*.dll
*.ttf
*.otf
*.zip
*.tar.gz
*.7z
*.rar
*.png
*.jpg
