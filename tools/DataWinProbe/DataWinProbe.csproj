<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <DeltaruneChineseDir Condition="'$(DeltaruneChineseDir)' == '' and '$(DELTARUNE_CHINESE_DIR)' != ''">$(DELTARUNE_CHINESE_DIR)</DeltaruneChineseDir>
    <DeltaruneChineseDir Condition="'$(DeltaruneChineseDir)' == ''">../../work/DeltaruneChinese</DeltaruneChineseDir>
  </PropertyGroup>
  <ItemGroup>
    <Reference Include="Underanalyzer">
      <HintPath>$(DeltaruneChineseDir)/src/lib/Underanalyzer.dll</HintPath>
    </Reference>
    <Reference Include="UndertaleModLib">
      <HintPath>$(DeltaruneChineseDir)/src/lib/UndertaleModLib.dll</HintPath>
    </Reference>
  </ItemGroup>
</Project>
