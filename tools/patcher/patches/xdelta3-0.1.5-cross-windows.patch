+                .clang_arg("--target=x86_64-pc-windows-gnu")
+                .clang_arg("--sysroot=/usr/x86_64-w64-mingw32")
+                .clang_arg("-I/usr/x86_64-w64-mingw32/include");
+        }
+
         for (key, val) in &defines {
             builder = builder.clang_arg(format!("-D{}={}", key, val));
         }
         let bindings = builder
             .header("xdelta3/xdelta3/xdelta3.h")
-            .parse_callbacks(Box::new(bindgen::CargoCallbacks))
-            .whitelist_function("xd3_.*")
+            .parse_callbacks(Box::new(bindgen::CargoCallbacks::new()))
+            .allowlist_function("xd3_.*")
             .generate()
             .expect("Unable to generate bindings");
 
